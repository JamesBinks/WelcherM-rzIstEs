@page "/"

<div class="scene">
    <img class="portrait portrait-left" src="images/images.jpg" alt="Friedrich März" />

    <div class="circle-wrap">
        <div class="ring ring-outer"></div>
        <div class="ring ring-inner"></div>
        <div class="card">
            <span class="eyebrow">Tag des Jahres</span>
            <h1 class="day-number">@todaysMarch</h1>
            <p class="subtitle">des März</p>
        </div>
    </div>

    <img class="portrait portrait-right" src="images/images.jpg" alt="Friedrich März" />
</div>
@@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400&display=swap');
<style>


    :root, html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    body {
        background: #0F1B2D;
        font-family: 'Inter', sans-serif;
        color: #F0EDE8;
    }

    .scene {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 60px;
        position: relative;
        padding: 40px;
        box-sizing: border-box;
    }

    .portrait {
        width: 220px;
        height: 220px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        border: 2px solid rgba(200, 149, 58, 0.5);
        box-shadow: 0 0 40px rgba(200, 149, 58, 0.15);
        flex-shrink: 0;
    }

    .portrait-right {
        transform: scaleX(-1);
    }

    .circle-wrap {
        position: relative;
        width: 340px;
        height: 340px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(200, 149, 58, 0.25);
        animation: breathe 4s ease-in-out infinite;
    }

    .ring-outer {
        width: 340px;
        height: 340px;
        animation-delay: 0s;
    }

    .ring-inner {
        width: 280px;
        height: 280px;
        border-color: rgba(200, 149, 58, 0.45);
        animation-delay: 0.6s;
    }

    @@keyframes breathe {
        0%, 100% {
            transform: scale(1);
            opacity: 0.6;
        }

        50% {
            transform: scale(1.04);
            opacity: 1;
        }
    }

    .card {
        position: relative;
        text-align: center;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .eyebrow {
        font-family: 'Inter', sans-serif;
        font-size: 0.7rem;
        font-weight: 300;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: black;
        opacity: 0.85;
    }

    .day-number {
        font-family: 'Cinzel', serif;
        font-size: 6rem;
        font-weight: 600;
        line-height: 1;
        margin: 8px 0 0;
        color: black;
        letter-spacing: -0.02em;
    }

    .subtitle {
        font-family: 'Cinzel', serif;
        font-size: 1.1rem;
        font-weight: 400;
        color: black;
        letter-spacing: 0.12em;
        margin: 0;
    }
</style>

@code {
    private int todaysMarch;

    protected override void OnInitialized()
    {
        var today = DateTime.Today;
        var firstOfMarch = new DateTime(today.Year, 3, 1);
        var diff = today - firstOfMarch;
        todaysMarch = Convert.ToInt32(diff.Days) + 1;

        if (todaysMarch < 0)
        {
            var marchLastYear = new DateTime(today.Year - 1, 3, 1);
            todaysMarch = Convert.ToInt32((today - marchLastYear).Days) + 1;
        }
    }
}